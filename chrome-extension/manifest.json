{
  "manifest_version": 3,
  "name": "PiDownloader Download Bridge",
  "description": "Hand Chrome downloads over to PiDownloader.",
  "version": "0.1.0",
  "minimum_chrome_version": "109",
  "permissions": [
    "contextMenus",
    "cookies",
    "downloads",
    "notifications",
    "storage",
    "webRequest",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": [
        "assets/hls.min.js",
        "src/content-styles.js",
        "src/content-utils.js",
        "src/content.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "PiDownloader",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
