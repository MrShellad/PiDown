{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PiDownloader",
  "version": "0.0.4",
  "identifier": "com.mrshell.PiDownloader",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PiDownloader",
        "width": 1600,
        "height": 768,
        "minWidth": 1360,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "scrollBarStyle": "fluentOverlay"
      },
      {
        "label": "float",
        "title": "PiDownloader Float",
        "url": "/float",
        "width": 500,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "scrollBarStyle": "fluentOverlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost webdav: https://webdav.localhost http://webdav.localhost; media-src 'self' asset: https://asset.localhost http://asset.localhost webdav: https://webdav.localhost http://webdav.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGODUwODBFMEUxQzg1M0UKUldRK2hSd09EZ2lGVHh5aGJ4bkcvY21FcVphQTFXUmhYcVBFbDU3OTdmZUYrZWdmakFKT1FGVEcK",
      "endpoints": [
        "https://pidown.onlyfan5.de/update.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese",
          "French",
          "German",
          "Japanese",
          "Korean",
          "Spanish"
        ],
        "displayLanguageSelector": true
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}