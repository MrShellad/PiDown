{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pidownloader",
  "version": "0.0.1",
  "identifier": "com.mrshell.PiDownloader",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PiDownloader",
        "width": 950,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "float",
        "title": "PiDownloader Float",
        "width": 140,
        "height": 140,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
